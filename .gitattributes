# Normalize text files to LF on checkout/checkin
* text eol=lf

# Binary files — prevent line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.pyd binary
*.pem binary
*.key binary
*.crt binary

# Explicit rules for common text file types
*.py text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.lock text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.html text eol=lf
*.css text eol=lf
*.env.template text eol=lf
Dockerfile text eol=lf
Caddyfile text eol=lf
